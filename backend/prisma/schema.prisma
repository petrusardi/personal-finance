generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int            @id @default(autoincrement())
  name           String
  email          String         @unique
  password       String
  createdAt      DateTime       @default(now())
  categories     Category[]
  transactions   Transaction[]
  budgets        Budget[]
  initialBalance InitialBalance?
  savings            Savings[]
  savingsEntries     SavingsEntry[]
  recurringTemplates RecurringTemplate[]
}

model Category {
  id           Int           @id @default(autoincrement())
  name         String
  type         CategoryType
  icon         String?
  color        String?
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  budgets             Budget[]
  recurringTemplates  RecurringTemplate[]

  @@unique([name, userId])
}

model Transaction {
  id            Int             @id @default(autoincrement())
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  description   String?
  date          DateTime
  categoryId    Int
  userId        Int
  paymentMethod PaymentMethod?
  category      Category        @relation(fields: [categoryId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
}

model Budget {
  id          Int      @id @default(autoincrement())
  limitAmount Decimal  @db.Decimal(12, 2)
  month       Int
  year        Int
  categoryId  Int
  userId      Int
  category    Category @relation(fields: [categoryId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([categoryId, userId, month, year])
}

model InitialBalance {
  id        Int     @id @default(autoincrement())
  amount    Decimal @db.Decimal(12, 2) @default(0)
  userId    Int     @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Savings {
  id        Int            @id @default(autoincrement())
  name      String
  icon      String         @default("💰")
  type      SavingsType
  target    Decimal?       @db.Decimal(12, 2)
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   SavingsEntry[]
  createdAt DateTime       @default(now())
}

model SavingsEntry {
  id        Int              @id @default(autoincrement())
  savingsId Int
  savings   Savings          @relation(fields: [savingsId], references: [id], onDelete: Cascade)
  amount    Decimal          @db.Decimal(12, 2)
  type      SavingsEntryType
  note      String?
  date      DateTime
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}

model RecurringTemplate {
  id            Int             @id @default(autoincrement())
  name          String
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  categoryId    Int
  paymentMethod PaymentMethod?
  userId        Int
  category      Category        @relation(fields: [categoryId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
}

enum SavingsType {
  TABUNGAN
  INVESTASI
}

enum SavingsEntryType {
  DEPOSIT
  WITHDRAWAL
  UPDATE
}

enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  E_WALLET
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
}
